{
  // OpenCode Simple — CDD & Spec-First Configuration
  // https://opencode.ai/docs/config
  "$schema": "https://opencode.ai/config.json",

  // ===== 规则：引入 rules/common/ 下的所有准则 =====
  "instructions": [
    "rules/common/*.md"
  ],

  // ===== MCP 服务器配置 (5 个核心) =====
  "mcp": {
    // 1. exa-web-search: 全网搜索代码、报错、最佳实践
    "exa-web-search": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server"],
      "environment": {
        "EXA_API_KEY": "{env:EXA_API_KEY}"
      }
    },

    // 2. context7: 查阅最新官方文档，防止 AI 幻觉
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },

    // 3. mcp-language-server: 本地 LSP 诊断（CDD 核心验证引擎）
    "mcp-language-server": {
      "type": "local",
      "command": ["npx", "-y", "mcp-language-server", "--stdio"]
    },

    // 4. memory: 跨会话记忆（持续学习必需）
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"]
    },

    // 5. sequential-thinking: 链式思考（CDD 编译错误分析必需）
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  }

  // ===== 按需启用的 MCP（取消注释即可） =====
  // "github": { "type": "local", "command": ["npx", "-y", "@modelcontextprotocol/server-github"], "environment": { "GITHUB_TOKEN": "{env:GITHUB_TOKEN}" } }
  // "ast-grep": AST-level structural code search/replace, useful for large-scale refactors
  // "grep-app": { "type": "remote", "url": "https://mcp.grep.app" }
}
