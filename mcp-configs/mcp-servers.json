{
  "_readme": "OpenCode MCP 服务器参考配置。将需要的服务器复制到 opencode.jsonc 的 mcp 字段中。",
  "_format": "OpenCode 要求: type (local/remote) + command (数组) 或 url (字符串)",

  "exa-web-search": {
    "type": "local",
    "command": ["npx", "-y", "exa-mcp-server"],
    "environment": {
      "EXA_API_KEY": "{env:EXA_API_KEY}"
    }
  },
  "context7": {
    "type": "remote",
    "url": "https://mcp.context7.com/mcp"
  },
  "mcp-language-server": {
    "type": "local",
    "command": ["npx", "-y", "mcp-language-server", "--stdio"]
  },
  "memory": {
    "type": "local",
    "command": ["npx", "-y", "@modelcontextprotocol/server-memory"]
  },
  "sequential-thinking": {
    "type": "local",
    "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
  },

  "_optional_servers": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": { "GITHUB_TOKEN": "{env:GITHUB_TOKEN}" }
    },
    "grep-app": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    }
  }
}
